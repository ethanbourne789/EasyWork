class EmailAccount extends DataClass implements Insertable<EmailAccount> {
  final int id;
  final String email;
  final String? displayName;
  final String? password;
  final String mailAccountJson;
  final String imapHost;
  final int imapPort;
  final bool imapUseSsl;
  final String smtpHost;
  final int smtpPort;
  final bool smtpUseSsl;
  final bool supportsIdle;
  final String? discoveredConfigJson;
  final String loginType;
  final String syncPeriod;
  final int syncInterval;
  final int accentColor;
  final DateTime createdAt;
  final DateTime updatedAt;
