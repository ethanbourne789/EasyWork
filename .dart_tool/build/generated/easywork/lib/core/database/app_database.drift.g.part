        accountId: accountId.present ? accountId.value : this.accountId,
        firstName: firstName.present ? firstName.value : this.firstName,
        lastName: lastName.present ? lastName.value : this.lastName,
        displayName: displayName ?? this.displayName,
        emailAddresses:
            emailAddresses.present ? emailAddresses.value : this.emailAddresses,
        phoneNumbers:
            phoneNumbers.present ? phoneNumbers.value : this.phoneNumbers,
        organization:
            organization.present ? organization.value : this.organization,
        department: department.present ? department.value : this.department,
        jobTitle: jobTitle.present ? jobTitle.value : this.jobTitle,
        notes: notes.present ? notes.value : this.notes,
        createdAt: createdAt ?? this.createdAt,
        updatedAt: updatedAt ?? this.updatedAt,
      );
  Contact copyWithCompanion(ContactsCompanion data) {
    return Contact(
      id: data.id.present ? data.id.value : this.id,
      accountId: data.accountId.present ? data.accountId.value : this.accountId,
      firstName: data.firstName.present ? data.firstName.value : this.firstName,
      lastName: data.lastName.present ? data.lastName.value : this.lastName,
      displayName:
          data.displayName.present ? data.displayName.value : this.displayName,
      emailAddresses: data.emailAddresses.present
          ? data.emailAddresses.value
