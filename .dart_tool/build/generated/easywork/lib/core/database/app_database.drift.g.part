          : Value(discoveredConfigJson),
      loginType: Value(loginType),
      syncPeriod: Value(syncPeriod),
      syncInterval: Value(syncInterval),
      accentColor: Value(accentColor),
      createdAt: Value(createdAt),
      updatedAt: Value(updatedAt),
